from collections import Counter

# You can copy the whole book and save as text file and run it.
# All double letter will not included like "is", "at", "on"... etc.
def most_repeated_word():
	with open("Genesis.txt","r", encoding="utf-8")as file: 
		words = file.read() # reading file
		# sanitizing words, eliminating numbers and special characters
		words = "".join(letter for letter in words if letter.isalpha() or letter.isspace()) 
		words = words.split()
		words = [word for word in words if len(word) >= 3]
		return Counter(words).most_common(10)[0][0]

the_word = most_repeated_word()
print(f"The Most Repeated Word: -- {the_word} --")
