import os 
import string 
import random


def clear_screen():
	os.system("clear")

# Password generation

#4 functions to validate passwowd based from the rules.
def password_validation(password):
	if len(password) < 8:
		return False, "Password must at least have 8 characters long."
	if not any(char.isdigit() for char in password):
		return False, "Password must at least have 1 digit."
	if not any(char.islower() for char in password):
		return False, "Password must at least have 1 lowercase letter."
	if not any(char.isupper() for char in password):
		return False, "Password must at least have 1 uppercase letter."
	if not any(char in string.punctuation for char in password):
		return False, "Password must at least have 1 special character."
	return True, "Password is strong."


#3a functions for password rules.
def password_rules():
	print("Password Rules:")
	print("Password must at least have 8 characters.")
	print("Password must at least have 1 digit (0-9).")
	print("Password must at least have 1 lowercase letter (a-z).")
	print("Password must at least have 1 uppercase letter (A-Z)")
	print("Password must at least have 1 special character (@,#,$...)")

#2a create manually generated password.
def manual_generation():
	password_rules() #3 create functions for password rules.
	print("\nManual Password Generation:")

	while True:
		password = input("Enter desired password: ")

		is_valid, comments = password_validation(password)

		if is_valid:
			print(f"Successful: {comments}")
			break
		else:
			print(f"Unsuccessful: {comments}")

#5a create a function for fully auto password generation
def auto_generation():
	while True:

		print("\nAuto Password Generation:")
		password_length = random.randint(8,20)

		password = [
			random.choice(string.digits),
			random.choice(string.ascii_lowercase),
			random.choice(string.ascii_uppercase),
			random.choice(string.punctuation)
		]
		password += random.choices(string.digits + string.ascii_lowercase + string.ascii_uppercase + string.punctuation,k=password_length-4)
		random.shuffle(password)
		password = "".join(password)
		print(password)

		is_valid, comments = password_validation(password)
		if is_valid:
			print(f"Successful: {comments}")
			break
		else:
			print(f"Unsuccessful: {comments}")


#1 create a function that has option between Auto and Manual.
def password_generation_options():
	clear_screen()
	print("Password Generation Options:")
	print("\n1:-------Manual\nOthers:--Auto")
	choices = input("\nEnter Your Choice: ")
	if choices == "1":
		manual_generation() #2 functions for manual generation
	else:
		auto_generation() #5 functions for fully auto password generation


password_generation_options()
