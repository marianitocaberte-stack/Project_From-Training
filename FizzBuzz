import os

def clear():
	os.system("clear")

# FizzBuzz

def while_loop():
	count = 1
	while count <= 30:
		output = ""
		if count % 3 == 0: output += "Fizz"
		if count % 5 == 0: output += "Buzz"
		print(f"{count}. {output}")
		count += 1

def for_loop():
	for i in range(1,31):
		output = ""
		if i % 3 == 0: output += "Fizz"
		if i % 5 == 0: output += "Buzz"
		print(f"{i}. {output}")


def fizzbuzz():
	clear()
	while_loop()
	print("========")
	for_loop()
fizzbuzz()
